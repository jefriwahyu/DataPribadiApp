@{
    ViewData["Title"] = "Home";
}

<div class="container">
    <!-- Hero Section -->
    <div class="row justify-content-center text-center mt-5 pt-5">
        <div class="col-md-8">
            <i class="bi bi-person-lines-fill" style="font-size: 5rem; color: #0d6efd;"></i>
            <h1 class="fw-bold mt-3">Selamat Datang</h1>
            <h4 class="text-muted mb-4">di Aplikasi Data Karyawan</h4>
            <p class="lead text-muted mb-5">
                Kelola data karyawan dengan mudah dan efisien. <br />
                Tambah, edit, dan pantau data pribadi karyawan dalam satu tempat.
            </p>
            <a asp-controller="Karyawan" asp-action="Index" class="btn btn-primary btn-lg px-5">
                <i class="bi bi-arrow-right-circle me-2"></i>Mulai Sekarang
            </a>
        </div>
    </div>

    <!-- Feature Cards -->
    <div class="row justify-content-center mt-5 g-4">
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0 h-100">
                <div class="card-body py-4">
                    <i class="bi bi-person-plus-fill fs-1 text-success mb-3"></i>
                    <h6 class="fw-bold">Tambah Data</h6>
                    <p class="text-muted small mb-0">Tambahkan data karyawan baru dengan mudah</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0 h-100">
                <div class="card-body py-4">
                    <i class="bi bi-search fs-1 text-primary mb-3"></i>
                    <h6 class="fw-bold">Cari Data</h6>
                    <p class="text-muted small mb-0">Cari data karyawan berdasarkan NIK atau Nama</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card text-center shadow-sm border-0 h-100">
                <div class="card-body py-4">
                    <i class="bi bi-pencil-square fs-1 text-warning mb-3"></i>
                    <h6 class="fw-bold">Edit Data</h6>
                    <p class="text-muted small mb-0">Perbarui informasi karyawan kapan saja</p>
                </div>
            </div>
        </div>
    </div>
</div>