@model List<DataKaryApp.Models.Karyawan>

@{
    ViewData["Title"] = "Aplikasi Data Pribadi";
}

<div class="container-fluid mt-4 px-4">
    <!-- Header -->
    <div class="d-flex align-items-center mb-3">
        <i class="bi bi-person-lines-fill fs-4 me-2"></i>
        <h5 class="mb-0 fw-bold">Aplikasi Data Karyawan</h5>
    </div>

    <!-- Search Card -->
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-action="Index">
                <div class="row g-2 align-items-end">
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">NIK</label>
                        <input name="nik" class="form-control form-control-sm" value="@Context.Request.Query["nik"]"
                               placeholder="Cari NIK..." />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label small fw-semibold">Nama</label>
                        <input name="nama" class="form-control form-control-sm" value="@Context.Request.Query["nama"]"
                               placeholder="Cari Nama..." />
                    </div>
                    <div class="col-md-6 d-flex gap-2">
                        <button type="submit" class="btn btn-primary btn-sm px-3">
                            <i class="bi bi-search me-1"></i>Search
                        </button>
                        <a asp-action="Create" class="btn btn-success btn-sm px-3">
                            <i class="bi bi-plus-lg me-1"></i>Add
                        </a>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <!-- Table Card -->
    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-bordered table-hover table-sm mb-0">
                <thead class="table-dark">
                    <tr>
                        <th class="text-center align-middle" style="width:50px">No</th>
                        <th class="align-middle" style="width:160px">NIK</th>
                        <th class="align-middle" style="width:200px">Nama Lengkap</th>
                        <th class="text-center align-middle" style="width:60px">Umur</th>
                        <th class="align-middle" style="width:110px">Tgl Lahir</th>
                        <th class="align-middle" style="width:120px">Jenis Kelamin</th>
                        <th class="align-middle" style="min-width:200px">Alamat</th>
                        <th class="align-middle" style="width:100px">Negara</th>
                        <th class="text-center align-middle" style="width:200px">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">
                                <i class="bi bi-inbox fs-5 d-block mb-1"></i>
                                Tidak ada data
                            </td>
                        </tr>
                    }
                    @for (int i = 0; i < Model.Count; i++)
                    {
                        var k = Model[i];
                        <tr>
                            <td class="text-center align-middle">@(i + 1)</td>
                            <td class="align-middle">@k.NIK</td>
                            <td class="align-middle">@k.NamaLengkap</td>
                            <td class="text-center align-middle">@k.Umur</td>
                            <td class="align-middle">@k.TanggalLahir?.ToString("dd-MMM-yy")</td>
                            <td class="align-middle">@k.JenisKelamin</td>
                            <td class="align-middle" style="min-width:200px">@k.Alamat</td>
                            <td class="align-middle">@k.Negara</td>
                            <td class="align-middle">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a asp-action="Detail" asp-route-id="@k.NIK" class="btn btn-info btn-sm py-0 px-2">
                                        <i class="bi bi-eye"></i> Detail
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@k.NIK" class="btn btn-warning btn-sm py-0 px-2">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <a href="#" class="btn btn-danger btn-sm py-0 px-2 btn-delete" data-id="@k.NIK"
                                       data-nama="@k.NamaLengkap">
                                        <i class="bi bi-trash"></i> Delete
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Modal Konfirmasi Delete -->
<div class="modal fade" id="modalDelete" tabindex="-1">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white py-2">
                <h6 class="modal-title">
                    <i class="bi bi-exclamation-triangle me-1"></i>Konfirmasi Hapus
                </h6>
            </div>
            <div class="modal-body text-center">
                <p class="mb-1">Anda yakin menghapus data</p>
                <strong id="deleteNama" class="text-danger"></strong> ?
            </div>
            <div class="modal-footer py-2 justify-content-center">
                <form id="formDelete" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger btn-sm px-4">OK</button>
                    <button type="button" class="btn btn-secondary btn-sm px-3" data-bs-dismiss="modal">Batal</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $('.btn-delete').click(function () {
            var id = $(this).data('id');
            var nama = $(this).data('nama');
            $('#deleteNama').text(nama);
            $('#formDelete').attr('action', '/Karyawan/Delete/' + id);
            $('#modalDelete').modal('show');
        });
    </script>
}